<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — ' : '' %><%= storeName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#08080f;--surface:#111120;--surface2:#1a1a2e;--border:#ffffff12;--accent:#00d4ff;--accent2:#7c3aed;--text:#e8e8f0;--muted:#8888a8}
    *{box-sizing:border-box}
    body{background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;min-height:100vh}
    .mono{font-family:'Space Mono',monospace}
    .card{background:var(--surface);border:1px solid var(--border);border-radius:12px;transition:border-color .2s,transform .2s,box-shadow .2s}
    .card:hover{border-color:var(--accent);box-shadow:0 0 20px #00d4ff18;transform:translateY(-2px)}
    .btn{display:inline-block;border-radius:8px;padding:.65rem 1.5rem;font-family:'Syne',sans-serif;font-weight:700;font-size:.95rem;text-align:center;transition:opacity .2s,transform .15s;cursor:pointer}
    .btn-primary{background:linear-gradient(135deg,var(--accent),#0099cc);color:#000}
    .btn-primary:hover{opacity:.9;transform:scale(1.02)}
    .btn-outline{background:var(--surface2);color:var(--text);border:1px solid var(--border)}
    .btn-outline:hover{border-color:var(--accent)}
    .badge{font-size:.7rem;font-family:'Space Mono',monospace;padding:.2rem .55rem;border-radius:4px;font-weight:700;letter-spacing:.04em}
    .badge-green{background:#00ff8822;color:#00ff88;border:1px solid #00ff8844}
    .badge-red{background:#ff444422;color:#ff6666;border:1px solid #ff444444}
    .badge-yellow{background:#ffaa0022;color:#ffcc44;border:1px solid #ffaa0044}
    .badge-gray{background:#88888822;color:#aaa;border:1px solid #88888844}
    .field{background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:8px;padding:.65rem 1rem;font-family:'Syne',sans-serif;transition:border-color .2s;outline:none;width:100%}
    .field:focus{border-color:var(--accent)}
    .mesh{position:fixed;top:0;left:0;width:100%;height:100%;background:radial-gradient(ellipse at 20% 20%,#00d4ff08 0%,transparent 50%),radial-gradient(ellipse at 80% 80%,#7c3aed08 0%,transparent 50%);pointer-events:none;z-index:0}
    .wrap{position:relative;z-index:1}
  </style>
  <%- typeof extraHead !== 'undefined' ? extraHead : '' %>
</head>
<body>
<div class="mesh"></div>
<div class="wrap">
<nav style="background:var(--surface);border-bottom:1px solid var(--border)" class="sticky top-0 z-50 px-6 py-4">
  <div class="max-w-6xl mx-auto flex items-center justify-between">
    <a href="/" class="text-2xl font-black" style="color:var(--accent)"><%= storeName %></a>
    <div class="flex items-center gap-4 text-sm">
      <a href="/" class="transition-colors hover:text-[var(--accent)]" style="color:var(--muted)">Beranda</a>
      <% if (isAdmin) { %>
        <a href="/admin" class="btn btn-primary py-1.5 px-4 text-sm">Admin</a>
        <a href="/admin/logout" class="text-xs transition-colors" style="color:var(--muted)">Logout</a>
      <% } %>
    </div>
  </div>
</nav>
