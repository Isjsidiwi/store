<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — ' : '' %><%= storeName %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #09090b; /* Very dark zinc */
      --surface: #18181b; /* Dark zinc */
      --surface2: #27272a;
      --border: #3f3f46;
      --accent: #3b82f6; /* Blue 500 */
      --accent-hover: #2563eb;
      --text: #f8fafc;
      --muted: #a1a1aa;
    }
    * { box-sizing: border-box; }
    body { background: var(--bg); color: var(--text); font-family: 'Inter', sans-serif; min-height: 100vh; -webkit-font-smoothing: antialiased; }
    .mono { font-family: 'JetBrains Mono', monospace; }
    
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; transition: all 0.3s ease; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); }
    .card:hover { border-color: #52525b; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05); }
    
    .btn { display: inline-flex; align-items: center; justify-content: center; border-radius: 10px; padding: 0.75rem 1.5rem; font-weight: 600; font-size: 0.95rem; transition: all 0.2s ease; cursor: pointer; }
    .btn-primary { background: var(--text); color: var(--bg); border: 1px solid transparent; }
    .btn-primary:hover { background: #e2e8f0; transform: translateY(-1px); }
    .btn-outline { background: transparent; color: var(--text); border: 1px solid var(--border); }
    .btn-outline:hover { background: var(--surface2); border-color: #52525b; }
    
    .badge { font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.6rem; border-radius: 9999px; letter-spacing: 0.02em; }
    .badge-green { background: rgba(34, 197, 94, 0.15); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.2); }
    .badge-red { background: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.2); }
    .badge-gray { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }
    
    .field { background: var(--bg); border: 1px solid var(--border); color: var(--text); border-radius: 10px; padding: 0.75rem 1rem; font-family: 'Inter', sans-serif; transition: all 0.2s ease; outline: none; width: 100%; box-shadow: inset 0 1px 2px rgba(0,0,0,0.1); }
    .field:focus { border-color: var(--accent); box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2); }
    
    .mesh { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at top, rgba(59,130,246,0.05) 0%, transparent 40%); pointer-events: none; z-index: 0; }
    .wrap { position: relative; z-index: 1; }
    
    nav { backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); background: rgba(9, 9, 11, 0.8) !important; border-bottom: 1px solid var(--border); }

    /* Loading Animation */
    #loader { position: fixed; inset: 0; background: var(--bg); z-index: 9999; display: flex; align-items: center; justify-content: center; transition: opacity 0.5s ease, visibility 0.5s; }
    .loader-ring { width: 40px; height: 40px; border: 3px solid rgba(59, 130, 246, 0.1); border-radius: 50%; border-top-color: var(--accent); animation: spin 0.8s linear infinite; }
    .loading-finished { opacity: 0; visibility: hidden; }

    /* Floating CS Button */
    .cs-float { position: fixed; bottom: 24px; right: 24px; z-index: 100; transform: translateY(0); transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .cs-float:hover { transform: translateY(-5px); }
    </style>
    <%- typeof extraHead !== 'undefined' ? extraHead : '' %>
    </head>
    <body>
    <div id="loader"><div class="loader-ring"></div></div>

    <!-- Floating Telegram CS -->
    <a href="https://t.me/rajasukii" target="_blank" class="cs-float group">
    <div class="flex items-center gap-3 bg-[#24A1DE] text-white px-4 py-3 rounded-2xl shadow-2xl shadow-[#24A1DE]/20 hover:bg-[#2293cd]">
    <div class="flex flex-col items-end">
      <span class="text-[10px] font-bold uppercase tracking-widest opacity-80 leading-none mb-1">Customer Service</span>
      <span class="text-xs font-bold leading-none">Hubungi Kami</span>
    </div>
    <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
    </div>
    </div>
    </a>

    <div class="mesh"></div>
    <div class="wrap">
    <nav class="sticky top-0 z-50 px-6 py-4">

  <div class="max-w-6xl mx-auto flex items-center justify-between">
    <a href="/" class="text-2xl font-extrabold tracking-tight flex items-center gap-2">
      <span class="w-8 h-8 rounded-lg bg-white text-black flex items-center justify-center text-sm">✦</span>
      <%= storeName %>
    </a>
    <div class="flex items-center gap-5 text-sm font-medium">
      <a href="/" class="transition-colors hover:text-white" style="color:var(--muted)">Katalog</a>
      <% if (isAdmin) { %>
        <a href="/admin" class="transition-colors hover:text-white" style="color:var(--muted)">Dashboard</a>
        <a href="/admin/logout" class="transition-colors text-red-400 hover:text-red-300">Logout</a>
      <% } %>
    </div>
  </div>
</nav>
