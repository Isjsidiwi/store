<% pageTitle = 'Produk — Admin' %>
<%- include('../partials/header') %>

<main class="max-w-6xl mx-auto px-6 py-12">
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-white">Katalog Produk</h1>
      <p class="text-zinc-400 mt-2">Tambah, edit, dan kelola stok digital key Anda.</p>
    </div>
    <a href="/admin" class="btn btn-outline text-sm py-2.5 px-5 rounded-xl border-zinc-800 hover:bg-zinc-900 transition-all flex items-center gap-2">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Kembali ke Dashboard
    </a>
  </div>

  <% if (success) { %>
  <div class="p-4 rounded-xl mb-8 text-sm bg-green-500/10 border border-green-500/20 text-green-400 flex items-center gap-3">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
    <%= success %>
  </div>
  <% } %>

  <!-- Add Product Section -->
  <div class="card p-8 mb-12 border-blue-500/10 bg-blue-500/[0.02]">
    <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
      Tambah Produk Baru
    </h2>
    <form method="POST" action="/admin/products/add" class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="md:col-span-2">
        <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2 ml-1">Nama Produk</label>
        <input type="text" name="name" class="field bg-zinc-900 border-zinc-800 focus:border-blue-500/50" placeholder="Contoh: Mobile Legends Weekly Pass" required>
      </div>
      <input type="hidden" name="price" value="0">
      <div>
        <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2 ml-1">Kategori</label>
        <input type="text" name="category" class="field bg-zinc-900 border-zinc-800" placeholder="Game / Software">
      </div>
      <div class="md:col-span-3">
        <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2 ml-1">URL Logo (Opsional)</label>
        <input type="url" name="logo_url" class="field bg-zinc-900 border-zinc-800" placeholder="https://link-gambar.com/logo.png">
      </div>
      <div class="md:col-span-3">
        <label class="block text-xs font-bold uppercase tracking-widest text-zinc-500 mb-2 ml-1">Deskripsi Ringkas</label>
        <textarea name="description" class="field bg-zinc-900 border-zinc-800" rows="2" placeholder="Jelaskan sedikit tentang produk ini..."></textarea>
      </div>
      <div class="md:col-span-3">
        <button type="submit" class="btn bg-white text-black hover:bg-zinc-200 font-bold px-8 py-3 rounded-xl shadow-xl shadow-white/5 transition-all">
          Buat Produk Sekarang
        </button>
      </div>
    </form>
  </div>

  <!-- Products List -->
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-xl font-bold text-white flex items-center gap-3">
      Daftar Produk
      <span class="badge bg-zinc-800 text-zinc-400 font-normal"><%= products.length %> total</span>
    </h2>
  </div>

  <div class="grid grid-cols-1 gap-4">
    <% if (products.length === 0) { %>
    <div class="card p-20 text-center text-zinc-600 border-dashed border-zinc-800">
      <div class="text-5xl mb-4 grayscale opacity-30">📦</div>
      <p class="font-medium">Belum ada produk terdaftar</p>
    </div>
    <% } else { %>
      <% products.forEach(p => { %>
      <div class="card p-5 border-zinc-800 bg-zinc-900/40 hover:bg-zinc-900/60 transition-all flex flex-col md:flex-row md:items-center gap-6">
        <div class="flex items-center gap-4 flex-1">
          <% if (p.logo_url) { %>
            <img src="<%= p.logo_url %>" class="w-14 h-14 rounded-2xl object-cover border border-zinc-700/50">
          <% } else { %>
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center border border-zinc-700/50 bg-zinc-800 text-2xl">📦</div>
          <% } %>
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-[10px] font-black uppercase tracking-widest text-blue-400"><%= p.category %></span>
              <span class="badge <%= p.is_active ? 'badge-green' : 'badge-gray' %> text-[9px]"><%= p.is_active ? 'AKTIF' : 'NONAKTIF' %></span>
            </div>
            <h3 class="font-bold text-lg text-white leading-tight"><%= p.name %></h3>
            <div class="text-xs text-zinc-500 mt-1 line-clamp-1"><%= p.description || 'Tidak ada deskripsi.' %></div>
          </div>
        </div>

        <div class="flex items-center gap-8 px-2 md:px-0 border-t md:border-t-0 md:border-l border-zinc-800 pt-4 md:pt-0 md:pl-8">
          <div class="text-center md:text-left">
            <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-1">Sisa Stok</div>
            <div class="font-black text-xl <%= p.stock > 0 ? 'text-white' : 'text-red-400' %>"><%= p.stock %> <span class="text-[10px] font-normal text-zinc-500">Key</span></div>
          </div>
          
          <div class="flex gap-2 ml-auto">
            <a href="/admin/products/<%= p.id %>/keys" class="btn btn-outline py-2 px-4 text-xs rounded-lg border-zinc-700 hover:border-zinc-500 font-bold flex items-center gap-2">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              Stok
            </a>
            <a href="/admin/products/<%= p.id %>/edit" class="btn btn-outline py-2 px-4 text-xs rounded-lg border-zinc-700 hover:border-zinc-500 font-bold flex items-center gap-2 text-blue-400">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
              Edit
            </a>
            <form method="POST" action="/admin/products/<%= p.id %>/delete" onsubmit="return confirm('Nonaktifkan produk ini?')">
              <button type="submit" class="btn btn-outline py-2 px-3 text-xs rounded-lg border-zinc-700 hover:border-red-500/30 text-zinc-500 hover:text-red-400 transition-colors">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
              </button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>
</main>

<%- include('../partials/footer') %>
