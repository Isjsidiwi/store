<% pageTitle = 'Keys — ' + product.name %>
<%- include('../partials/header') %>

<main class="max-w-4xl mx-auto px-6 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <a href="/admin/products" class="mono text-xs mb-2 inline-block" style="color:var(--muted)">← Kembali ke Produk</a>
      <h1 class="text-3xl font-black">Kelola Keys</h1>
      <p class="text-sm mt-1" style="color:var(--muted)"><%= product.name %></p>
    </div>
    <div class="text-right">
      <div class="mono text-xs mb-1" style="color:var(--muted)">Tersedia</div>
      <div class="text-3xl font-black" style="color:var(--accent)"><%= keys.filter(k => !k.is_used).length %> key</div>
    </div>
  </div>

  <% if (success) { %>
  <div class="p-3 rounded-xl mb-5 text-sm" style="background:#00ff8815;border:1px solid #00ff8833;color:#00ff88">✅ <%= success %></div>
  <% } %>

  <!-- Add Keys Form -->
  <div class="card p-6 mb-8">
    <h2 class="text-lg font-bold mb-2">Tambah Keys Baru</h2>
    <p class="text-sm mb-4" style="color:var(--muted)">Masukkan satu key per baris. Setiap baris = 1 stok.</p>
    <form method="POST" action="/admin/products/<%= product.id %>/keys/add" class="flex flex-col gap-4">
      <textarea name="keys_text" class="field mono text-sm" rows="8" placeholder="KEY-XXXX-YYYY-ZZZZ&#10;KEY-AAAA-BBBB-CCCC&#10;KEY-1234-5678-9012&#10;..." required style="font-size:.8rem;line-height:1.6"></textarea>
      <div>
        <button type="submit" class="btn btn-primary px-8">+ Tambah Keys</button>
        <span class="text-xs ml-3" style="color:var(--muted)">Dapat diisi lisensi, kode akses, serial, akun, dll.</span>
      </div>
    </form>
  </div>

  <!-- Keys List -->
  <div class="card overflow-hidden">
    <div class="p-4 flex items-center justify-between" style="border-bottom:1px solid var(--border)">
      <h2 class="font-bold">Semua Keys (<%= keys.length %>)</h2>
      <div class="flex gap-3 mono text-xs">
        <span class="badge badge-green"><%= keys.filter(k=>!k.is_used).length %> tersedia</span>
        <span class="badge badge-gray"><%= keys.filter(k=>k.is_used).length %> terpakai</span>
      </div>
    </div>
    <% if (keys.length === 0) { %>
    <div class="p-12 text-center" style="color:var(--muted)">
      <div class="text-3xl mb-3">🔑</div>
      <p>Belum ada key. Tambahkan key di atas.</p>
    </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr style="border-bottom:1px solid var(--border)">
            <th class="text-left p-4 mono text-xs uppercase tracking-wider" style="color:var(--muted)">Key</th>
            <th class="text-left p-4 mono text-xs uppercase tracking-wider" style="color:var(--muted)">Status</th>
            <th class="text-left p-4 mono text-xs uppercase tracking-wider" style="color:var(--muted)">Order ID</th>
            <th class="text-left p-4 mono text-xs uppercase tracking-wider" style="color:var(--muted)">Dipakai</th>
            <th class="p-4"></th>
          </tr>
        </thead>
        <tbody>
          <% keys.forEach(k => { %>
          <tr style="border-bottom:1px solid var(--border)" class="hover:bg-[var(--surface2)] transition-colors">
            <td class="p-4 mono text-xs" style="color: <%= k.is_used ? 'var(--muted)' : 'var(--text)' %>; text-decoration: <%= k.is_used ? 'line-through' : 'none' %>">
              <%= k.key_value.length > 40 ? k.key_value.substring(0,40) + '…' : k.key_value %>
            </td>
            <td class="p-4">
              <span class="badge <%= k.is_used ? 'badge-gray' : 'badge-green' %>">
                <%= k.is_used ? 'TERPAKAI' : 'TERSEDIA' %>
              </span>
            </td>
            <td class="p-4 mono text-xs" style="color:var(--muted)">
              <%= k.order_id ? '#' + k.order_id.substring(0,8).toUpperCase() : '-' %>
            </td>
            <td class="p-4 mono text-xs" style="color:var(--muted)"><%= k.used_at || '-' %></td>
            <td class="p-4">
              <% if (!k.is_used) { %>
              <form method="POST" action="/admin/products/<%= product.id %>/keys/<%= k.id %>/delete" onsubmit="return confirm('Hapus key ini?')">
                <button type="submit" class="btn text-xs py-1 px-2.5" style="background:#ff444415;color:#ff8888;border:1px solid #ff444433">Hapus</button>
              </form>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</main>

<%- include('../partials/footer') %>
