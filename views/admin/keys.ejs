<% pageTitle = 'Keys — ' + product.name %>
<%- include('../partials/header') %>

<main class="max-w-4xl mx-auto px-6 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <a href="/admin/products" class="mono text-xs mb-2 inline-block" style="color:var(--muted)">← Kembali ke Produk</a>
      <h1 class="text-3xl font-black">Kelola Keys</h1>
      <p class="text-sm mt-1" style="color:var(--muted)"><%= product.name %></p>
    </div>
    <div class="text-right">
      <div class="mono text-xs mb-1" style="color:var(--muted)">Tersedia</div>
      <div class="text-3xl font-black" style="color:var(--accent)"><%= keys.filter(k => !k.is_used).length %> key</div>
    </div>
  </div>

  <% if (success) { %>
  <div class="p-3 rounded-xl mb-5 text-sm" style="background:#00ff8815;border:1px solid #00ff8833;color:#00ff88">✅ <%= success %></div>
  <% } %>

  <!-- Add Keys Form -->
  <div class="card p-6 mb-8">
    <h2 class="text-lg font-bold mb-2">Tambah Keys Baru</h2>
    <p class="text-sm mb-4" style="color:var(--muted)">Pilih jenis produk dan masukkan satu key per baris.</p>
    <form method="POST" action="/admin/products/<%= product.id %>/keys/add" class="flex flex-col gap-4">
      <div>
        <label class="block text-sm font-semibold mb-2">Pilih Jenis (Varian)</label>
        <select name="variant_id" class="field" required>
          <option value="" disabled selected>-- Pilih Jenis --</option>
          <% variants.forEach(v => { %>
            <option value="<%= v.id %>"><%= v.name %> (Rp <%= Number(v.price).toLocaleString('id-ID') %>)</option>
          <% }) %>
        </select>
        <% if (variants.length === 0) { %>
          <p class="text-xs mt-2 text-red-400">⚠️ Kamu belum membuat varian produk. Buat varian di halaman Edit Produk terlebih dahulu.</p>
        <% } %>
      </div>
      <div>
        <label class="block text-sm font-semibold mb-2">Daftar Key</label>
        <textarea name="keys_text" class="field mono text-sm" rows="8" placeholder="KEY-XXXX-YYYY-ZZZZ&#10;KEY-AAAA-BBBB-CCCC&#10;..." required <%= variants.length === 0 ? 'disabled' : '' %>></textarea>
      </div>
      <div>
        <button type="submit" class="btn btn-primary px-8" <%= variants.length === 0 ? 'disabled' : '' %>>+ Tambah Keys</button>
      </div>
    </form>
  </div>

  <!-- Keys List -->
  <div class="card overflow-hidden">
    <form method="POST" action="/admin/products/<%= product.id %>/keys/bulk-delete">
    <div class="p-4 flex items-center justify-between" style="border-bottom:1px solid var(--border)">
      <h2 class="font-bold">Semua Keys (<%= keys.length %>)</h2>
      <% if (keys.length > 0) { %>
      <button type="submit" class="btn text-xs py-1.5 px-3" style="background:#ff444415;color:#ff8888;border:1px solid #ff444433" onclick="return confirm('Yakin ingin menghapus semua key yang dicentang?\\n\\nPERHATIAN: Jika ada key yang sudah terpakai, datanya akan hilang dari riwayat pembeli.')">Hapus Terpilih</button>
      <% } %>
    </div>
    <% if (keys.length === 0) { %>
    <div class="p-12 text-center" style="color:var(--muted)">
      <div class="text-3xl mb-3">🔑</div>
      <p>Belum ada key. Tambahkan key di atas.</p>
    </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr style="border-bottom:1px solid var(--border)">
            <th class="p-4 w-10"><input type="checkbox" id="selectAllKeys" class="w-4 h-4 accent-[var(--accent)] cursor-pointer"></th>
            <th class="text-left p-4 mono text-xs uppercase tracking-wider" style="color:var(--muted)">Jenis</th>
            <th class="text-left p-4 mono text-xs uppercase tracking-wider" style="color:var(--muted)">Key</th>
            <th class="text-left p-4 mono text-xs uppercase tracking-wider" style="color:var(--muted)">Status</th>
            <th class="text-left p-4 mono text-xs uppercase tracking-wider" style="color:var(--muted)">Order</th>
            <th class="p-4"></th>
          </tr>
        </thead>
        <tbody>
          <% keys.forEach(k => { %>
          <tr style="border-bottom:1px solid var(--border)" class="hover:bg-[var(--surface2)] transition-colors">
            <td class="p-4"><input type="checkbox" name="key_ids" value="<%= k.id %>" class="key-cb w-4 h-4 accent-[var(--accent)] cursor-pointer"></td>
            <td class="p-4">
              <span class="font-bold text-xs"><%= k.variant_name || 'N/A' %></span>
            </td>
            <td class="p-4 mono text-xs" style="color: <%= k.is_used ? 'var(--muted)' : 'var(--text)' %>">
              <%= k.key_value.length > 30 ? k.key_value.substring(0,30) + '…' : k.key_value %>
            </td>
            <td class="p-4">
              <span class="badge <%= k.is_used ? 'badge-gray' : 'badge-green' %>">
                <%= k.is_used ? 'TERPAKAI' : 'TERSEDIA' %>
              </span>
            </td>
            <td class="p-4 mono text-xs" style="color:var(--muted)">
              <%= k.order_id ? '#' + k.order_id.substring(0,8).toUpperCase() : '-' %>
            </td>
            <td class="p-4">
              <a href="#" onclick="event.preventDefault(); if(confirm('Hapus key ini? <%= k.is_used ? '\\n\\nPERHATIAN: Key ini sudah terpakai oleh pesanan. Menghapus key akan menghilangkan data key dari riwayat pesanan pembeli.' : '' %>')) { const f = document.createElement('form'); f.method='POST'; f.action='/admin/products/<%= product.id %>/keys/<%= k.id %>/delete'; document.body.appendChild(f); f.submit(); }" class="btn text-xs py-1 px-2.5" style="background:#ff444415;color:#ff8888;border:1px solid #ff444433">Hapus</a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
    </form>
  </div>
</main>
<script>
  const selectAll = document.getElementById('selectAllKeys');
  if(selectAll) {
    selectAll.addEventListener('change', (e) => {
      document.querySelectorAll('.key-cb').forEach(cb => cb.checked = e.target.checked);
    });
  }
</script>

<%- include('../partials/footer') %>
