<% pageTitle = 'Admin Login' %>
<%- include('../partials/header') %>

<main class="max-w-sm mx-auto px-6 py-20">
  <div class="text-center mb-8">
    <div class="text-4xl mb-3">🔐</div>
    <h1 class="text-2xl font-black">Admin Panel</h1>
    <p class="text-sm mt-1" style="color:var(--muted)">Masuk untuk mengelola toko</p>
  </div>

  <% if (error) { %>
  <div class="p-3 rounded-xl mb-4 text-sm text-center" style="background:#ff444415;border:1px solid #ff444433;color:#ff8888"><%= error %></div>
  <% } %>

  <form method="POST" action="/admin/login" class="card p-6 flex flex-col gap-4">
    <div>
      <label class="block text-sm font-semibold mb-2">Username</label>
      <input type="text" name="username" class="field" placeholder="admin" required autofocus>
    </div>
    <div>
      <label class="block text-sm font-semibold mb-2">Password</label>
      <input type="password" name="password" class="field" placeholder="••••••••" required>
    </div>
    <button type="submit" class="btn btn-primary w-full mt-2">Masuk →</button>
  </form>
</main>

<%- include('../partials/footer') %>
