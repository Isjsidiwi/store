<% pageTitle = 'Pesanan #' + order.id.substring(0,8) %>
<%
const isPending = order.status === 'pending';
const isPaid = order.status === 'paid';
const isExpired = order.status === 'expired';
const expiredTs = new Date(order.expired_at).getTime();
%>
<%- include('partials/header', { extraHead: isPending ? `<style>
  @keyframes pulse-ring { 0%,100%{transform:scale(1);opacity:.6} 50%{transform:scale(1.05);opacity:1} }
  .pulse { animation: pulse-ring 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .spin { animation: spin 1s linear infinite; }
</style>` : '' }) %>

<main class="max-w-lg mx-auto px-6 py-12">

  <!-- Header status -->
  <div class="text-center mb-10">
    <% if (isPaid) { %>
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-500/10 text-green-400 mb-5">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
      </div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">Pembayaran Berhasil!</h1>
      <p class="mt-3 text-sm text-zinc-400">Key produk digital kamu sudah siap di bawah ini.</p>
    <% } else if (isExpired) { %>
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-red-500/10 text-red-400 mb-5">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">Pesanan Kadaluarsa</h1>
      <p class="mt-3 text-sm text-zinc-400">Waktu pembayaran telah habis. Silakan buat pesanan baru.</p>
    <% } else { %>
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-blue-500/10 text-blue-400 mb-5 pulse">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-white">Menunggu Pembayaran</h1>
      <p class="mt-3 text-sm text-zinc-400">Scan QRIS di bawah, key otomatis dikirim setelah terbayar.</p>
    <% } %>
  </div>

  <!-- Order Info Card -->
  <div class="card p-6 mb-6 border-zinc-800 bg-zinc-900/50">
    <div class="flex justify-between items-center mb-5 pb-4 border-b border-zinc-800">
      <span class="text-xs font-bold tracking-widest uppercase text-zinc-500">Order ID</span>
      <span class="mono text-sm font-medium text-zinc-300">#<%= order.id.substring(0,8).toUpperCase() %></span>
    </div>
    <div class="flex items-start gap-4 mb-5">
      <% if (order.logo_url) { %>
        <img src="<%= order.logo_url %>" class="w-12 h-12 rounded-xl object-cover border border-zinc-700/50">
      <% } else { %>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center border border-zinc-700/50 bg-zinc-800">📦</div>
      <% } %>
      <div class="flex-1 pt-0.5">
        <div class="font-bold text-white leading-tight"><%= order.product_name %></div>
        <div class="text-[11px] font-medium text-blue-400 mt-1 uppercase tracking-wider"><%= order.variant_name %></div>
        <div class="text-sm mt-2 text-zinc-400"><%= order.customer_name %> &middot; <%= order.customer_email %></div>
      </div>
    </div>
    <div class="flex justify-between items-center pt-4 border-t border-zinc-800 mt-2">
      <span class="text-sm font-medium text-zinc-400">Total Bayar</span>
      <span class="font-bold text-lg text-white">Rp <%= Number(order.unique_amount).toLocaleString('id-ID') %></span>
    </div>
  </div>

  <% if (isPending) { %>
  <!-- QRIS Section -->
  <div class="card p-8 text-center mb-6 border-blue-500/20 bg-blue-500/5 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-500 to-indigo-500"></div>
    <p class="text-sm font-medium mb-2 text-zinc-300">Scan QRIS dengan nominal <strong class="text-white font-bold">TEPAT:</strong></p>
    <div class="text-4xl font-extrabold my-3 tracking-tight text-white">Rp <%= Number(order.unique_amount).toLocaleString('id-ID') %></div>
    <p class="text-xs mb-6 text-blue-400/80 font-medium bg-blue-500/10 py-2 px-4 rounded-full inline-block">Sistem membaca nominal unik untuk verifikasi otomatis</p>

    <% if (order.qris_url) { %>
      <div class="inline-block p-4 rounded-2xl bg-white mb-6 shadow-xl shadow-black/20">
        <img src="<%= order.qris_url %>" alt="QRIS" class="w-56 h-56 object-contain">
      </div>
    <% } else { %>
      <div class="w-56 h-56 mx-auto rounded-2xl flex flex-col items-center justify-center mb-6 border-2 border-dashed border-zinc-700 bg-zinc-900/50">
        <svg class="text-zinc-600 mb-2" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 9h.01"/><path d="M15 9h.01"/><path d="M9 15h.01"/><path d="M15 15h.01"/></svg>
        <p class="text-xs text-zinc-500">QRIS belum tersedia</p>
      </div>
    <% } %>

    <!-- Countdown -->
    <div id="countdown" class="mono text-sm font-medium text-zinc-400 bg-zinc-900/80 py-2 px-4 rounded-xl inline-block border border-zinc-800">Menghitung waktu...</div>
  </div>

  <!-- Status Checker -->
  <div id="status-box" class="card p-5 text-center mb-6 border-zinc-800 bg-zinc-900/50">
    <div class="flex items-center justify-center gap-3 text-sm font-medium text-zinc-400">
      <div class="w-4 h-4 rounded-full border-2 spin border-zinc-600 border-t-blue-400"></div>
      Mengecek status pembayaran secara otomatis...
    </div>
  </div>

  <script>
    const orderId = '<%= order.id %>';
    const expiredAt = <%= expiredTs %>;
    let pollInterval;

    function formatTime(ms) {
      const s = Math.max(0, Math.floor(ms / 1000));
      const m = Math.floor(s / 60);
      const sec = s % 60;
      return `${m}:${sec.toString().padStart(2,'0')}`;
    }

    function updateCountdown() {
      const remaining = expiredAt - Date.now();
      const el = document.getElementById('countdown');
      if (remaining <= 0) {
        el.textContent = 'Waktu pembayaran habis!';
        el.className = 'mono text-sm font-medium text-red-400 bg-red-500/10 py-2 px-4 rounded-xl inline-block border border-red-500/20';
      } else {
        el.textContent = `Kadaluarsa dalam ${formatTime(remaining)}`;
        if (remaining < 60000) {
          el.className = 'mono text-sm font-medium text-red-400 bg-red-500/10 py-2 px-4 rounded-xl inline-block border border-red-500/20';
        }
      }
    }

    async function checkStatus() {
      try {
        const res = await fetch(`/api/order/${orderId}/status`);
        const data = await res.json();
        const box = document.getElementById('status-box');

        if (data.status === 'paid') {
          clearInterval(pollInterval);
          box.innerHTML = `<div class="flex items-center justify-center gap-2 text-green-400 font-bold"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg> Pembayaran diterima! Memuat key...</div>`;
          setTimeout(() => location.reload(), 1500);
        } else if (data.status === 'expired') {
          clearInterval(pollInterval);
          location.reload();
        } else if (data.status === 'paid_no_stock') {
          clearInterval(pollInterval);
          box.innerHTML = `<div class="text-yellow-500 font-bold">⚠️ Pembayaran diterima, namun stok sistem kosong. Harap hubungi admin.</div>`;
        }
      } catch(e) {
        console.error(e);
      }
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
    pollInterval = setInterval(checkStatus, 5000);
    checkStatus();
  </script>
  <% } %>

  <% if (isPaid && order.key_value) { %>
  <!-- Key Display -->
  <div class="card p-8 mb-6 border-blue-500/30 bg-gradient-to-b from-blue-500/10 to-transparent relative overflow-hidden" style="box-shadow: 0 0 40px rgba(59, 130, 246, 0.15)">
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-400 to-indigo-500"></div>
    <div class="text-xs font-bold uppercase tracking-widest text-blue-400 mb-4 flex items-center gap-2">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      Produk Key Anda
    </div>
    
    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
      <div id="key-display" class="mono font-bold text-lg md:text-xl flex-1 px-5 py-4 rounded-xl break-all bg-black/40 border border-zinc-700/50 text-white shadow-inner"><%= order.key_value %></div>
      <button onclick="copyKey()" class="btn py-4 px-6 text-sm bg-white text-black hover:bg-zinc-200 shadow-lg font-bold sm:w-auto w-full" id="copy-btn">Salin Key</button>
    </div>
    
    <div class="mt-5 p-3 rounded-lg bg-yellow-500/10 border border-yellow-500/20 text-xs text-yellow-500/90 flex items-start gap-2">
      <svg class="shrink-0 mt-0.5" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      <p>Segera simpan key ini di tempat yang aman. Pesanan ini tidak dapat dibuka ulang jika Anda meninggalkan halaman.</p>
    </div>
  </div>
  
  <script>
    function copyKey() {
      navigator.clipboard.writeText('<%= order.key_value.replace(/'/g, "\\'") %>').then(() => {
        const btn = document.getElementById('copy-btn');
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline mr-1"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg> Disalin!';
        btn.classList.replace('bg-white', 'bg-green-500');
        btn.classList.replace('text-black', 'text-white');
        
        setTimeout(() => {
          btn.textContent = 'Salin Key';
          btn.classList.replace('bg-green-500', 'bg-white');
          btn.classList.replace('text-white', 'text-black');
        }, 2000);
      });
    }
  </script>
  <% } %>

  <div class="flex flex-col gap-3 mt-8">
    <% if (isExpired) { %>
      <a href="/produk/<%= order.slug %>" class="btn w-full block text-center py-4 text-base bg-white text-black hover:bg-zinc-200 transition-all font-bold rounded-xl">Buat Pesanan Baru</a>
    <% } %>
    <a href="/" class="btn btn-outline w-full block text-center py-3 text-sm border-zinc-800 hover:bg-zinc-900 rounded-xl">Kembali ke Katalog Toko</a>
  </div>

</main>

<%- include('partials/footer') %>
