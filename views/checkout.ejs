<% pageTitle = 'Checkout — ' + product.name %>
<%- include('partials/header') %>

<main class="max-w-lg mx-auto px-6 py-12">
  <a href="/produk/<%= product.slug %>" class="inline-flex items-center gap-2 text-sm font-medium text-zinc-400 hover:text-white transition-colors mb-8">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    Kembali
  </a>

  <h1 class="text-3xl font-extrabold tracking-tight mb-2 text-white text-center sm:text-left">Checkout</h1>
  <p class="text-sm mb-8 text-zinc-400 text-center sm:text-left">Selesaikan pembayaran untuk mendapatkan key instan.</p>

  <!-- Product Summary -->
  <div class="card p-5 flex flex-col sm:flex-row items-center sm:items-start gap-4 mb-8 bg-zinc-900/50 border-zinc-800 text-center sm:text-left">
    <% if (product.logo_url) { %>
      <img src="<%= product.logo_url %>" alt="" class="w-16 h-16 sm:w-14 sm:h-14 rounded-xl object-cover border border-zinc-700/50">
    <% } else { %>
      <div class="w-16 h-16 sm:w-14 sm:h-14 rounded-xl flex items-center justify-center text-xl border border-zinc-700/50 bg-zinc-800">📦</div>
    <% } %>
    <div class="flex-1">
      <div class="font-bold text-white text-lg sm:text-base"><%= product.name %></div>
      <div class="text-xs font-medium text-blue-400 mt-1 sm:mt-0.5"><%= variant.name %></div>
    </div>
    <div class="mt-2 sm:mt-0 sm:text-right w-full sm:w-auto text-center">
      <div class="font-bold text-white text-lg sm:text-base">Rp <%= Number(variant.price).toLocaleString('id-ID') %></div>
    </div>
  </div>

  <% if (error) { %>
  <div class="p-4 rounded-xl mb-6 text-sm bg-red-500/10 border border-red-500/20 text-red-400 flex items-center gap-3">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <%= error %>
  </div>
  <% } %>

  <form method="POST" action="/checkout/<%= product.slug %>/<%= variant.id %>" class="flex flex-col gap-5">
    <div class="space-y-1.5">
      <label class="block text-sm font-semibold text-zinc-300 ml-1">Nama Lengkap</label>
      <input type="text" name="customer_name" class="field bg-zinc-900 border-zinc-800 focus:border-blue-500/50 text-white placeholder-zinc-600" placeholder="Contoh: Budi Santoso" required>
    </div>
    <div class="space-y-1.5">
      <label class="block text-sm font-semibold text-zinc-300 ml-1">Email Aktif</label>
      <input type="email" name="customer_email" class="field bg-zinc-900 border-zinc-800 focus:border-blue-500/50 text-white placeholder-zinc-600" placeholder="budi@email.com" required>
      <p class="text-xs text-zinc-500 ml-1">Digunakan untuk melacak pesanan dan bukti pembelian.</p>
    </div>

    <div class="p-5 rounded-2xl text-sm bg-zinc-900/80 border border-zinc-800 mt-2">
      <div class="flex justify-between mb-3 text-zinc-400">
        <span>Harga <%= variant.name %></span>
        <span class="font-medium text-zinc-300">Rp <%= Number(variant.price).toLocaleString('id-ID') %></span>
      </div>
      <div class="flex justify-between mb-4 text-zinc-400">
        <span>Kode Unik (Verifikasi)</span>
        <span class="font-medium text-blue-400">+ Rp <%= Number(variant.price).toLocaleString('id-ID').replace(/\d/g, 'x') %></span>
      </div>
      <div class="flex justify-between font-bold pt-4 border-t border-zinc-800/80 text-base text-white">
        <span>Total Transfer</span>
        <span>Rp <%= Number(variant.price).toLocaleString('id-ID') %> + <span class="text-blue-400 text-sm">kode</span></span>
      </div>
    </div>
    
    <div class="flex items-start gap-3 p-4 rounded-xl bg-blue-500/5 border border-blue-500/10 text-xs text-zinc-400 mt-1">
      <svg class="shrink-0 text-blue-400 mt-0.5" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-5.88 5.88a1 1 0 1 0 3 3l2.5-2.5"/><path d="m21 21-2-2"/></svg>
      <p>Kode unik 3 digit akan ditambahkan secara otomatis pada halaman QRIS berikutnya agar sistem dapat memproses pembayaran secara instan 24/7.</p>
    </div>

    <button type="submit" class="btn w-full mt-4 py-4 text-base bg-white text-black hover:bg-zinc-200 hover:-translate-y-0.5 transition-all shadow-xl shadow-white/10 rounded-xl font-bold">
      Lanjut ke Pembayaran QRIS →
    </button>
  </form>
</main>

<%- include('partials/footer') %>
