<% pageTitle = product.name %>
<%- include('partials/header') %>

<main class="max-w-3xl mx-auto px-6 py-12">
  <a href="/" class="mono text-xs mb-8 inline-flex items-center gap-2 hover:text-[var(--accent)] transition-colors" style="color:var(--muted)">← Kembali</a>

  <div class="card p-8">
    <div class="flex items-start gap-5 mb-6">
      <% if (product.logo_url) { %>
        <img src="<%= product.logo_url %>" alt="<%= product.name %>" class="w-20 h-20 rounded-2xl object-cover" style="border:1px solid var(--border)">
      <% } else { %>
        <div class="w-20 h-20 rounded-2xl flex items-center justify-center text-4xl" style="background:var(--surface2)">📦</div>
      <% } %>
      <div class="flex-1">
        <div class="mono text-xs uppercase tracking-widest mb-1" style="color:var(--muted)"><%= product.category %></div>
        <h1 class="text-3xl font-black mb-2"><%= product.name %></h1>
        <span class="badge <%= product.stock > 0 ? 'badge-green' : 'badge-red' %>">
          <%= product.stock > 0 ? 'Stok tersedia: ' + product.stock : 'Stok habis' %>
        </span>
      </div>
    </div>

    <% if (product.description) { %>
    <div class="mb-6 p-4 rounded-xl text-sm leading-relaxed" style="background:var(--surface2);color:var(--muted)">
      <%= product.description %>
    </div>
    <% } %>

    <div class="flex items-center justify-between py-4 mb-6" style="border-top:1px solid var(--border);border-bottom:1px solid var(--border)">
      <div>
        <div class="text-sm mb-1" style="color:var(--muted)">Harga</div>
        <div class="mono font-bold text-3xl" style="color:var(--accent)">Rp <%= Number(product.price).toLocaleString('id-ID') %></div>
      </div>
      <div class="text-right">
        <div class="text-sm mb-1" style="color:var(--muted)">Pembayaran</div>
        <div class="mono text-sm">QRIS</div>
      </div>
    </div>

    <div class="p-4 rounded-xl mb-6 text-sm" style="background:#00d4ff08;border:1px solid #00d4ff22">
      <div class="font-bold mb-2" style="color:var(--accent)">ℹ️ Cara Beli</div>
      <ol class="list-decimal list-inside space-y-1" style="color:var(--muted)">
        <li>Klik tombol Beli & isi nama serta email</li>
        <li>Scan QRIS yang muncul dengan jumlah <strong style="color:var(--text)">tepat</strong></li>
        <li>Key dikirim otomatis setelah pembayaran terdeteksi</li>
        <li>Simpan email kamu untuk cek pesanan</li>
      </ol>
    </div>

    <% if (product.stock > 0) { %>
      <a href="/checkout/<%= product.slug %>" class="btn btn-primary w-full block text-center">Beli Sekarang →</a>
    <% } else { %>
      <div class="btn btn-outline w-full text-center opacity-50 cursor-not-allowed">Stok Habis</div>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
